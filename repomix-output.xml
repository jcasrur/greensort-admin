                            {isSuperAdmin && (
                              <td className="px-6 py-4 text-right">
                                <button
                                  onClick={async () => {
                                    if (window.confirm(`Revoke invite for ${inv.email}?`)) {
                                      await supabase.from('admin_invitations').delete().eq('id', inv.id);
