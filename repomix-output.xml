<file path="src/UpcycleManagement.jsx">
import React, { useState, useEffect } from 'react';
import { supabase } from './supabase';
import Sidebar from './Sidebar';
import { useTheme, ThemedCard } from './ThemeContext';
import { useToast } from './Toast';
import { useConfirm } from './ConfirmModal';
import { logAdminAction } from './auditLog';
import GuidePanel from './GuidePanel';

export default function UpcycleManagement() {
  const [activeTab, setActiveTab] = useState('pending');
  const { isLightMode, t } = useTheme();
  const toast = useToast();
  const confirm = useConfirm();
  const [submissions, setSubmissions] = useState([]);
  const [loading, setLoading] = useState(true);
  const [selectedItem, setSelectedItem] = useState(null);

  // ── All logic is preserved exactly as-is ──────────────────────────────────

  const fetchSubmissions = async () => {
    setLoading(true);
    try {
      const { data, error } = await supabase
        .from('upcycle_submissions')
        .select('*')
        .order('created_at', { ascending: false });
      if (error) throw error;
      setSubmissions(data || []);
    } catch (e) {
      toast.error('Failed to load submissions');
    } finally { setLoading(false); }
  };

  useEffect(() => { fetchSubmissions(); }, []);

  const handleApprove = async (item) => {
    const ok = await confirm({ title: 'Approve submission?', message: `Approve "${item.title}" by ${item.submitted_by}? This will make it visible to the community.`, confirmLabel: 'Approve', confirmStyle: 'success' });
    if (!ok) return;
    try {
      await supabase.from('upcycle_submissions').update({ status: 'approved', reviewed_at: new Date().toISOString() }).eq('id', item.id);
      await logAdminAction({ action: 'APPROVE_UPCYCLE', targetTable: 'upcycle_submissions', targetId: item.id, details: { title: item.title } });
      toast.success(`"${item.title}" approved`);
      fetchSubmissions();
      setSelectedItem(null);
    } catch (e) { toast.error('Failed to approve'); }
  };

  const handleReject = async (item) => {
    const ok = await confirm({ title: 'Reject submission?', message: `Reject "${item.title}"? The user will not be notified unless you message them separately.`, confirmLabel: 'Reject', confirmStyle: 'danger' });
    if (!ok) return;
    try {
      await supabase.from('upcycle_submissions').update({ status: 'rejected', reviewed_at: new Date().toISOString() }).eq('id', item.id);
      await logAdminAction({ action: 'REJECT_UPCYCLE', targetTable: 'upcycle_submissions', targetId: item.id, details: { title: item.title } });
      toast.success(`"${item.title}" rejected`);
      fetchSubmissions();
      setSelectedItem(null);
    } catch (e) { toast.error('Failed to reject'); }
  };

  const filtered = submissions.filter(s => activeTab === 'all' || s.status === activeTab);
  const counts = {
    pending:  submissions.filter(s => s.status === 'pending').length,
    approved: submissions.filter(s => s.status === 'approved').length,
    rejected: submissions.filter(s => s.status === 'rejected').length,
  };

  // ── Design helpers ─────────────────────────────────────────────────────────

  const STATUS = {
    pending: {
      dot:   'bg-amber-400',
      label: isLightMode ? 'text-amber-700' : 'text-amber-400',
      chip:  isLightMode ? 'bg-amber-50 border-amber-200'         : 'bg-amber-400/10 border-amber-400/20',
      bar:   isLightMode ? 'bg-amber-300/60'                      : 'bg-amber-400/50',
    },
    approved: {
      dot:   isLightMode ? 'bg-[#3D7A58]' : 'bg-[#7DBF96]',
      label: isLightMode ? 'text-[#3D7A58]' : 'text-[#7DBF96]',
      chip:  isLightMode ? 'bg-[#EAF4EE] border-[#C0DAC9]'       : 'bg-[#5E9E7A]/10 border-[#5E9E7A]/25',
      bar:   isLightMode ? 'bg-[#3D7A58]'                         : 'bg-[#5E9E7A]',
    },
    rejected: {
      dot:   'bg-red-400',
      label: isLightMode ? 'text-red-600' : 'text-red-400',
      chip:  isLightMode ? 'bg-red-50 border-red-200'             : 'bg-red-400/10 border-red-400/20',
      bar:   isLightMode ? 'bg-red-300/60'                        : 'bg-red-400/50',
    },
  };

  const StatusChip = ({ status }) => {
    const cfg = STATUS[status] || STATUS.pending;
    return (
      <span className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg border text-[10px] font-medium capitalize ${cfg.chip} ${cfg.label}`}>
        <span className={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${cfg.dot}`} />
        {status}
      </span>
    );
  };

  const TABS = ['pending', 'approved', 'rejected', 'all'];

  return (
    <div className={`flex h-screen w-full font-sans ${t.bg} transition-colors duration-300 overflow-hidden`}>
      <Sidebar />

      <div className="flex-1 h-full overflow-y-auto" style={{ scrollbarWidth: 'none' }}>
        <div className="p-7 lg:p-9 max-w-[1300px] mx-auto">

          {/* ── Header ────────────────────────────────────────────────────── */}
          <div className="flex items-start justify-between mb-7 gap-4">
            <div>
              <h1 className={`text-xl font-semibold ${t.textMain}`}>Upcycle</h1>
              <p className={`${t.textMuted} mt-0.5 text-sm`}>Review and moderate user-submitted project ideas</p>
            </div>

            {/* Summary pills */}
            <div className="flex items-center gap-2 flex-wrap justify-end">
              {Object.entries(counts).map(([key, val]) =>
                val > 0 ? (
                  <span key={key} className={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl border text-xs font-medium ${STATUS[key]?.chip} ${STATUS[key]?.label}`}>
                    <span className={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${STATUS[key]?.dot}`} />
                    {val} {key}
                  </span>
                ) : null
              )}
            </div>
          </div>

          {/* ── Tabs ──────────────────────────────────────────────────────── */}
          <div className={`inline-flex items-center gap-1 p-1 rounded-xl border mb-6 ${
            isLightMode ? 'bg-[#EEF2EC] border-[#E0E8DC]' : 'bg-[#191F1C] border-white/[0.05]'
          }`}>
            {TABS.map(tab => (
              <button
                key={tab}
                onClick={() => setActiveTab(tab)}
                className={`flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium capitalize transition-all duration-150 ${
                  activeTab === tab
                    ? (isLightMode
                        ? 'bg-white text-[#3D7A58] shadow-sm'
                        : 'bg-[#1E2822] text-[#7DBF96] border border-white/[0.05]')
                    : t.textMuted
                }`}
              >
                {tab}
                {counts[tab] > 0 && (
                  <span className={`text-[9px] font-bold px-1.5 py-0.5 rounded-full ${
                    tab === 'pending'
                      ? (isLightMode ? 'bg-amber-100 text-amber-700' : 'bg-amber-400/15 text-amber-400')
                      : (isLightMode ? 'bg-[#F3F6F1] text-[#7A9082]' : 'bg-white/[0.06] text-[#5E7A67]')
                  }`}>
                    {counts[tab]}
                  </span>
                )}
              </button>
            ))}
          </div>

          {/* ── Content ───────────────────────────────────────────────────── */}
          {loading ? (
            <div className={`flex items-center justify-center h-48 rounded-2xl border text-sm animate-pulse ${
              isLightMode ? 'bg-white border-[#E6EBE4] text-[#7A9082]' : 'bg-[#191F1C] border-white/[0.06] text-[#5E7A67]'
            }`}>
              Loading submissions…
            </div>

          ) : filtered.length === 0 ? (
            <div className={`flex flex-col items-center justify-center py-20 rounded-2xl border ${
              isLightMode ? 'bg-white border-[#E6EBE4]' : 'bg-[#191F1C] border-white/[0.06]'
            }`}>
              <div className={`w-11 h-11 rounded-2xl flex items-center justify-center mb-3 ${t.iconBg1}`}>
                <svg className={`w-5 h-5 ${t.accentText}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.75} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <p className={`text-sm ${t.textMuted}`}>No {activeTab} submissions.</p>
            </div>

          ) : (
            <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-8">
              {filtered.map((item) => {
                const cfg = STATUS[item.status] || STATUS.pending;
                return (
                  <div
                    key={item.id}
                    className={`group flex flex-col rounded-2xl border overflow-hidden transition-all duration-200 ${
                      isLightMode
                        ? 'bg-white border-[#E6EBE4] hover:border-[#C0DAC9] hover:shadow-[0_4px_20px_rgba(61,122,88,0.07)]'
                        : 'bg-[#191F1C] border-white/[0.06] hover:border-[#5E9E7A]/25'
                    }`}
                  >
                    {/* Status accent bar along the top */}
                    <div className={`h-0.5 w-full flex-shrink-0 ${cfg.bar}`} />

                    <div className="p-5 flex flex-col gap-3 flex-1">

                      {/* Title + status badge */}
                      <div className="flex items-start justify-between gap-3">
                        <div className="flex-1 min-w-0">
                          <p className={`text-sm font-semibold ${t.textMain} leading-snug`}>
                            {item.title || 'Untitled Submission'}
                          </p>
                          <p className={`text-[11px] ${t.textMuted} mt-0.5`}>
                            by {item.submitted_by || 'Unknown'}
                          </p>
                        </div>
                        <StatusChip status={item.status} />
                      </div>

                      {/* Description */}
                      <p className={`text-xs leading-relaxed ${t.textMuted} line-clamp-3 flex-1`}>
                        {item.description || 'No description provided.'}
                      </p>

                      {/* Materials pill */}
                      {item.materials && (
                        <div className={`flex items-center gap-2 px-3 py-2 rounded-xl text-[11px] ${t.textMuted} ${
                          isLightMode ? 'bg-[#F6F8F5]' : 'bg-white/[0.03]'
                        }`}>
                          <svg className={`w-3.5 h-3.5 flex-shrink-0 ${t.accentText}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.75} d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                          </svg>
                          <span className="truncate">{item.materials}</span>
                        </div>
                      )}

                      {/* Date */}
                      <p className={`text-[10px] ${t.textFaint}`}>
                        {new Date(item.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                      </p>

                      {/* Action buttons — only for pending */}
                      {item.status === 'pending' && (
                        <div className={`flex gap-2 pt-2 border-t ${t.divider}`}>
                          <button
                            onClick={() => handleApprove(item)}
                            className={`flex-1 py-2 rounded-xl text-xs font-medium transition-all flex items-center justify-center gap-1.5 ${
                              isLightMode
                                ? 'bg-[#EAF4EE] text-[#3D7A58] hover:bg-[#DCF0E5]'
                                : 'bg-[#5E9E7A]/10 text-[#7DBF96] hover:bg-[#5E9E7A]/18'
                            }`}
                          >
                            <svg className="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 13l4 4L19 7"/>
                            </svg>
                            Approve
                          </button>
                          <button
                            onClick={() => handleReject(item)}
                            className={`flex-1 py-2 rounded-xl text-xs font-medium transition-all flex items-center justify-center gap-1.5 ${
                              isLightMode
                                ? 'bg-red-50 text-red-600 hover:bg-red-100'
                                : 'bg-red-400/10 text-red-400 hover:bg-red-400/18'
                            }`}
                          >
                            <svg className="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                            Reject
                          </button>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          )}

          <div className="h-12" />
        </div>
      </div>

      <GuidePanel page="upcycle" />
    </div>
  );
}
